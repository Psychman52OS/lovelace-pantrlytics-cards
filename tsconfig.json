{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES2015",
    "lib": ["ES2019", "DOM"],
    "declaration": false,
    "sourceMap": false,
    "outDir": "dist",
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
